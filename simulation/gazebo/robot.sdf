<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="h747_elite_robot">

    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ==================== LINKS ==================== -->

    <!-- Main chassis body -->
    <link name="chassis">
      <pose>0 0 0.0475 0 0 0</pose>
      <inertial>
        <mass>3.0</mass>
        <inertia>
          <ixx>0.045</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.045</iyy>
          <iyz>0</iyz>
          <izz>0.075</izz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry>
          <cylinder>
            <radius>0.175</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu>
              <mu2>0.3</mu2>
              <fdir1>0 0 1</fdir1>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <poissons_ratio>0.4</poissons_ratio>
            <elastic_modulus>1e7</elastic_modulus>
          </contact>
        </surface>
      </collision>
      <visual name="chassis_visual">
        <geometry>
          <cylinder>
            <radius>0.175</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
          <specular>0.05 0.05 0.05 1.0</specular>
        </material>
      </visual>

      <!-- LIDAR dome visual -->
      <visual name="lidar_dome_visual">
        <pose>0.08 0 0.055 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.15 0.15 0.15 1.0</diffuse>
        </material>
      </visual>

      <!-- Bumper front visual -->
      <visual name="bumper_front_visual">
        <pose>0.17 0 0.01 0 0 0</pose>
        <geometry>
          <box>
            <size>0.03 0.3 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.35 0.35 0.35 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0 0.16 0.0125 0 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>5.0e-5</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1.0e-4</iyy>
          <iyz>0</iyz>
          <izz>5.0e-5</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>0.5</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <poissons_ratio>0.45</poissons_ratio>
            <elastic_modulus>5e6</elastic_modulus>
          </contact>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0 -0.16 0.0125 0 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>5.0e-5</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1.0e-4</iyy>
          <iyz>0</iyz>
          <izz>5.0e-5</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>0.5</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <poissons_ratio>0.45</poissons_ratio>
            <elastic_modulus>5e6</elastic_modulus>
          </contact>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Caster wheel (passive, rear) -->
    <link name="caster_wheel">
      <pose>-0.12 0 0.005 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>1.0e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1.0e-6</iyy>
          <iyz>0</iyz>
          <izz>1.0e-6</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.25 0.25 0.25 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- ==================== JOINTS ==================== -->

    <!-- Left wheel joint (revolute) -->
    <joint name="left_wheel_joint" type="revolute">
      <pose>0 0.16 0.0125 0 0 0</pose>
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>0.8</effort>
          <velocity>38.0</velocity>
        </limit>
        <dynamics>
          <damping>0.0</damping>
          <friction>0.01</friction>
        </dynamics>
        <use_parent_model_frame>true</use_parent_model_frame>
      </axis>
    </joint>

    <!-- Right wheel joint (revolute) -->
    <joint name="right_wheel_joint" type="revolute">
      <pose>0 -0.16 0.0125 0 0 0</pose>
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>0.8</effort>
          <velocity>38.0</velocity>
        </limit>
        <dynamics>
          <damping>0.0</damping>
          <friction>0.01</friction>
        </dynamics>
        <use_parent_model_frame>true</use_parent_model_frame>
      </axis>
    </joint>

    <!-- Caster joint (ball / fixed) -->
    <joint name="caster_joint" type="ball">
      <pose>-0.12 0 0.005 0 0 0</pose>
      <parent>chassis</parent>
      <child>caster_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>0.01</effort>
          <velocity>10.0</velocity>
        </limit>
      </axis>
    </joint>

    <!-- ==================== SENSORS ==================== -->

    <!-- LIDAR / Laser scanner -->
    <link name="laser_frame">
      <pose>0.08 0 0.065 0 0 0</pose>
    </link>
    <joint name="laser_joint" type="fixed">
      <parent>chassis</parent>
      <child>laser_frame</child>
    </joint>

    <!-- Camera frame -->
    <link name="camera_frame">
      <pose>0.12 0 0.04 0 0 0</pose>
    </link>
    <joint name="camera_joint" type="fixed">
      <parent>chassis</parent>
      <child>camera_frame</child>
    </joint>

    <!-- IMU frame -->
    <link name="imu_frame">
      <pose>0.02 0 0.02 0 0 0</pose>
    </link>
    <joint name="imu_joint" type="fixed">
      <parent>chassis</parent>
      <child>imu_frame</child>
    </joint>

    <!-- ==================== PLUGINS ==================== -->

    <!-- Differential drive plugin -->
    <plugin name="diff_drive" filename="libDiffDrivePlugin.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.32</wheel_separation>
      <wheel_diameter>0.07</wheel_diameter>
      <torque>0.8</torque>
      <command_topic>/cmd_vel</command_topic>
      <odometry_topic>/odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_wheel_tf>true</publish_wheel_tf>
      <publish_wheel_joint_pose>true</publish_wheel_joint_pose>
      <update_rate>100</update_rate>
      <legacy_mode>false</legacy_mode>
    </plugin>

    <!-- LIDAR plugin -->
    <plugin name="laser" filename="libRayPlugin.so">
      <topic>/scan</topic>
      <frame>laser_frame</frame>
      <update_rate>6.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>8.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <visualize>true</visualize>
      <always_on>true</always_on>
    </plugin>

    <!-- Camera plugin -->
    <plugin name="camera" filename="libCameraPlugin.so">
      <topic>/camera/image_raw</topic>
      <frame>camera_frame</frame>
      <update_rate>30.0</update_rate>
      <camera_name>main_camera</camera_name>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.1</near>
        <far>100</far>
      </clip>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.02</stddev>
      </noise>
      <distortion>
        <k1>0.0</k1>
        <k2>0.0</k2>
        <p1>0.0</p1>
        <p2>0.0</p2>
        <center>0.5 0.5</center>
      </distortion>
      <pose>0 0 0 0 0 0</pose>
      <lens>
        <fov>1.047</fov>
        <focal_length>3.04</focal_length>
        <aspect_ratio>1.333</aspect_ratio>
      </lens>
    </plugin>

    <!-- IMU plugin -->
    <plugin name="imu" filename="libIMUPlugin.so">
      <topic>/imu/data</topic>
      <frame>imu_frame</frame>
      <update_rate>1000.0</update_rate>
      <noise>
        <type>gaussian</type>
        <accelerometer>
          <mean>0.0</mean>
          <stddev>0.002</stddev>
          <bias_stddev>0.001</bias_stddev>
        </accelerometer>
        <gyroscope>
          <mean>0.0</mean>
          <stddev>0.00005</stddev>
          <bias_stddev>0.00002</bias_stddev>
        </gyroscope>
      </noise>
    </plugin>

    <!-- Motor simulation plugin -->
    <plugin name="motor_sim" filename="libSimpleFOCPlugin.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <motor_resistance>0.45</motor_resistance>
      <motor_inductance>0.00012</motor_inductance>
      <torque_constant>0.052</torque_constant>
      <pole_pairs>7</pole_pairs>
      <gear_ratio>30</gear_ratio>
      <inertia>0.000012</inertia>
      <damping>0.000005</damping>
      <max_current>3.0</max_current>
      <current_loop_bandwidth>2000</current_loop_bandwidth>
      <speed_loop_bandwidth>200</speed_loop_bandwidth>
      <foc_update_rate>20000</foc_update_rate>
      <pwm_frequency>50000</pwm_frequency>
      <encoder_cpr>12</encoder_cpr>
      <enable_foc>true</enable_foc>
      <enable_sensorless_fallback>true</enable_sensorless_fallback>
      <topic>/motor_state</topic>
    </plugin>

  </model>
</sdf>
